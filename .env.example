# Copy these values to backend/.env for FastAPI service
APP_NAME=EchoWell Intelligence API
API_V1_PREFIX=/api/v1
DEBUG=true
SECRET_KEY=replace-this
ACCESS_TOKEN_EXPIRE_MINUTES=10080
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=echowell
POSTGRES_URI=postgresql+asyncpg://postgres:postgres@localhost:5432/echowell_analytics
ML_ARTIFACT_DIR=backend/app/ml/artifacts
HF_EMOTION_MODEL=bhadresh-savani/bert-base-uncased-emotion
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
ALLOWED_ORIGINS=http://localhost:5173
