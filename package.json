{
  "name": "echowell",
  "version": "2.0.0",
  "description": "AI Mental Wellness Intelligence Platform",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm:dev:api\" \"npm:dev:web\"",
    "dev:api": "python -m uvicorn app.main:app --app-dir backend --reload --host 0.0.0.0 --port 8000",
    "dev:web": "vite --config vite.config.js",
    "build": "vite build --config vite.config.js",
    "preview": "vite preview --config vite.config.js",
    "start": "python -m uvicorn app.main:app --app-dir backend --host 0.0.0.0 --port 8000",
    "lint": "eslint .",
    "train:ml": "python backend/scripts/train_models.py",
    "test:ml": "python -m pytest -c backend/pytest.ini backend/tests",
    "test:e2e": "cypress run"
  },
  "dependencies": {
    "axios": "^1.8.4",
    "d3": "^7.9.0",
    "plotly.js-dist-min": "^3.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-plotly.js": "^2.6.0",
    "react-router-dom": "^6.30.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.20.0",
    "@tailwindcss/vite": "^4.1.4",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "cypress": "^14.5.1",
    "eslint": "^9.20.1",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.18",
    "globals": "^15.14.0",
    "vite": "^6.2.4"
  }
}
